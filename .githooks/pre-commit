#!/bin/bash
# Pre-commit hook: runs staticcheck, lint (with --fix), and tests.
# If golangci-lint --fix modifies any tracked files the commit is aborted —
# the developer must review the fixes, stage them, and commit again.

set -e

echo "🔍 Running pre-commit checks..."

# ── staticcheck ────────────────────────────────────────────────────────────────
if ! make staticcheck; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "❌ staticcheck failed — please fix the issues above before committing."
    echo "   To bypass (not recommended): git commit --no-verify"
    exit 1
fi

# ── golangci-lint --fix ────────────────────────────────────────────────────────
# Snapshot tracked-file state before lint so we can detect auto-fixes.
PRE_LINT=$(git diff --name-only)

make lint

# If lint modified any tracked files, abort and ask the developer to stage them.
POST_LINT=$(git diff --name-only)
if [ "$PRE_LINT" != "$POST_LINT" ]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⚠️  golangci-lint --fix modified files that are not staged:"
    echo ""
    git diff --name-only
    echo ""
    echo "Review the changes, stage them, and commit again:"
    echo "  git diff          # review"
    echo "  git add -p        # stage selectively, or"
    echo "  git add .         # stage all"
    echo "  git commit        # retry"
    echo ""
    echo "To bypass (not recommended): git commit --no-verify"
    exit 1
fi

# ── tests ──────────────────────────────────────────────────────────────────────
if ! make test; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "❌ Tests failed — please fix them before committing."
    echo "   To bypass (not recommended): git commit --no-verify"
    exit 1
fi

echo ""
echo "✓ All pre-commit checks passed!"
exit 0
